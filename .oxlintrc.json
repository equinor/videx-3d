{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["import", "oxc", "eslint", "react", "react-perf", "jsx-a11y", "typescript"],
  "ignorePatterns": [
    "node_modules/*",
    "dist/*",
    "config/*",
    "vite.config.js",
    "**/.*"
    ],
  "categories": {
    "correctness": "error",
    "suspicious": "off",
    "perf": "off"
  },
  "rules": {
    "no-unused-expressions": ["error", {"allowTernary": true, "allowShortCircuit": true}],
    "react/react-in-jsx-scope": "off"
  },
  "overrides": [
    {
        "files": ["tests/*"],
        "plugins": ["vitest"],
    }
  ]
}